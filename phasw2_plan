import unittest
import random
from dataclasses import dataclass
from typing import Dict, Any, List, Optional
from enum import Enum

# ==============================================================================
# MOCK ARCHITECTURAL DEPENDENCIES (To make this single block runnable immediately)
# ==============================================================================
class ItemType(Enum):
    WEAPON = 1
    ARMOR = 2
    POTION = 3
    SCROLL = 4
    MISC = 5

class EquipmentSlot(Enum):
    HEAD = 1
    CHEST = 2
    MAIN_HAND = 3
    OFF_HAND = 4

@dataclass
class Item:
    item_id: str
    name: str
    item_type: ItemType
    equipment_slot: Optional[EquipmentSlot]
    weight: int
    damage_bonus: int
    to_hit_bonus: int
    defense_bonus: int
    description: str

# ==============================================================================
# PHASE 2 IMPLEMENTATION MODULES (mobs.py, items.py, levels.py code)
# ==============================================================================
@dataclass
class MobTemplate:
    id: str
    name: str
    symbol_key: str
    base_hp: int
    base_power: int
    base_defense: int
    description: str
    ability_name: Optional[str] = None
    ability_description: Optional[str] = None

class MobGenerator:
    @staticmethod
    def from_llm_json(json_data: Dict[str, Any]) -> MobTemplate:
        """Parses and validates LLM generation output with strict defaults."""
        return MobTemplate(
            id=json_data.get("id", f"mob_{random.randint(1000, 9999)}"),
            name=json_data.get("name", "Unknown Horror"),
            symbol_key=json_data.get("symbol_key", "enemy_minion"),
            base_hp=max(1, json_data.get("base_hp", 10)),
            base_power=max(1, json_data.get("base_power", 3)),
            base_defense=max(0, json_data.get("base_defense", 1)),
            description=json_data.get("description", "A dark shape shifts in the shadows."),
            ability_name=json_data.get("ability_name"),
            ability_description=json_data.get("ability_description")
        )

    @staticmethod
    def scale_to_floor(template: MobTemplate, floor_level: int) -> Dict[str, Any]:
        """Applies mathematical game rules to raw LLM templates to keep balance."""
        scale_factor = 1.0 + (floor_level - 1) * 0.25
        return {
            "name": template.name,
            "symbol_key": template.symbol_key,
            "hp": int(template.base_hp * scale_factor),
            "max_hp": int(template.base_hp * scale_factor),
            "power": int(template.base_power * (1.0 + (floor_level - 1) * 0.15)),
            "defense": template.base_defense + (floor_level // 3),
            "description": template.description
        }

class ItemGenerator:
    @staticmethod
    def from_llm_json(json_data: Dict[str, Any]) -> Item:
        """Translates LLM creative output directly into an executable inventory Item."""
        raw_type = str(json_data.get("item_type", "MISC")).upper()
        try:
            item_type = ItemType[raw_type]
        except KeyError:
            item_type = ItemType.MISC

        raw_slot = json_data.get("equipment_slot")
        eq_slot = None
        if raw_slot:
            try:
                eq_slot = EquipmentSlot[str(raw_slot).upper()]
            except KeyError:
                eq_slot = None

        return Item(
            item_id=json_data.get("item_id", f"item_{random.randint(1000, 9999)}"),
            name=json_data.get("name", "Strange Trinket"),
            item_type=item_type,
            equipment_slot=eq_slot,
            weight=json_data.get("weight", 1),
            damage_bonus=json_data.get("damage_bonus", 0),
            to_hit_bonus=json_data.get("to_hit_bonus", 0),
            defense_bonus=json_data.get("defense_bonus", 0),
            description=json_data.get("description", "An unidentifiable object glints on the ground.")
        )

@dataclass
class LevelTheme:
    floor: int
    name: str
    description: str
    ambient_messages: List[str]
    allowed_mobs: List[str]
    spawn_density: float

class LevelGenerator:
    @staticmethod
    def generate_theme(json_data: Dict[str, Any], floor: int) -> LevelTheme:
        return LevelTheme(
            floor=floor,
            name=json_data.get("name", f"Dungeon Floor {floor}"),
            description=json_data.get("description", "Damp stone walls stretch into darkness."),
            ambient_messages=json_data.get("ambient_messages", ["You hear water dripping."]),
            allowed_mobs=json_data.get("allowed_mobs", ["enemy_minion"]),
            spawn_density=min(0.1, json_data.get("spawn_density", 0.05))
        )


# ==============================================================================
# COMPREHENSIVE UNIT TESTING SUITE
# ==============================================================================
class TestPhase2ContentGeneration(unittest.TestCase):

    def setUp(self):
        # Seed random to make sure auto-generated IDs remain reproducible if needed
        random.seed(42)

        self.valid_mob_json = {
            "name": "Shadow Creeper",
            "symbol_key": "enemy_elite",
            "base_hp": 20,
            "base_power": 6,
            "base_defense": 2,
            "description": "An inky silhouette stretching along the walls.",
            "ability_name": "Shadow Ambush",
            "ability_description": "Strikes from darkness."
        }

    # --- MOB GENERATION TESTS ---
    def test_mob_successful_parsing(self):
        """Ensure properly structured JSON translates cleanly to a MobTemplate."""
        mob = MobGenerator.from_llm_json(self.valid_mob_json)
        self.assertEqual(mob.name, "Shadow Creeper")
        self.assertEqual(mob.symbol_key, "enemy_elite")
        self.assertEqual(mob.base_hp, 20)

    def test_mob_corrupt_json_fallback(self):
        """Ensure missing or corrupted fields default to safe architectural values."""
        corrupt_json = {"name": "Glitchy Enemy", "base_hp": -50}
        mob = MobGenerator.from_llm_json(corrupt_json)

        self.assertEqual(mob.name, "Glitchy Enemy")
        self.assertEqual(mob.symbol_key, "enemy_minion")  # Default assigned
        self.assertEqual(mob.base_hp, 1)                  # Capped to minimum allowed floor

    def test_mob_floor_progression_scaling(self):
        """Verify mathematical formulas correctly scale stats based on depth."""
        template = MobGenerator.from_llm_json(self.valid_mob_json)

        floor_1_mob = MobGenerator.scale_to_floor(template, floor_level=1)
        floor_5_mob = MobGenerator.scale_to_floor(template, floor_level=5)

        # Floor 1 scaling baseline check
        self.assertEqual(floor_1_mob["hp"], 20)
        # Floor 5 scaling math calculation check (1.0 + (5 - 1) * 0.25 = 2.0x factor)
        self.assertEqual(floor_5_mob["hp"], 40)

    # --- ITEM GENERATION TESTS ---
    def test_item_valid_enum_mapping(self):
        """Verify string identifiers map perfectly to functional gameplay Enums."""
        weapon_json = {
            "name": "Duskblade",
            "item_type": "WEAPON",
            "equipment_slot": "MAIN_HAND",
            "damage_bonus": 4,
            "weight": 3
        }
        item = ItemGenerator.from_llm_json(weapon_json)
        self.assertEqual(item.item_type, ItemType.WEAPON)
        self.assertEqual(item.equipment_slot, EquipmentSlot.MAIN_HAND)

    def test_item_invalid_enum_string_fallback(self):
        """Ensure unmapped or hallucinated items drop gracefully into generic categories."""
        weird_json = {
            "name": "Unstable Artifact",
            "item_type": "NUCLEAR_LAUNCHER",  # Hallucinated Type
            "equipment_slot": "EYEBALL"        # Hallucinated Slot
        }
        item = ItemGenerator.from_llm_json(weird_json)
        self.assertEqual(item.item_type, ItemType.MISC)  # Safe structural fallback
        self.assertIsNone(item.equipment_slot)            # Invalid slot ignored

    # --- LEVEL GENERATION TESTS ---
    def test_level_spawn_density_safety_ceiling(self):
        """Enforce ceilings so LLMs don't flood the engine arrays with mobs."""
        insane_level_json = {
            "name": "The Murder Room",
            "spawn_density": 0.95,  # 95% spawn chance would break standard loop balance
            "allowed_mobs": ["enemy_minion"]
        }
        theme = LevelGenerator.generate_theme(insane_level_json, floor=2)
        # Verify engine logic hard-caps the density to maximum safe budget threshold (10%)
        self.assertLessEqual(theme.spawn_density, 0.1)

    def test_level_ambient_messages_array_handling(self):
        """Ensure narrative atmospheric text defaults seamlessly if completely missing."""
        empty_json = {}
        theme = LevelGenerator.generate_theme(empty_json, floor=1)
        self.assertIsInstance(theme.ambient_messages, list)
        self.assertTrue(len(theme.ambient_messages) > 0)


